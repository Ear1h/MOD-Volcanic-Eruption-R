// Define the common spawn/death states to reduce copy pasting
#define DIABOLIST_FIRE_SPAWN_STATES								\
Spawn:															\
	TNT1 A 1													\
	TNT1 A 0 A_PlaySound(MDIFLM)								\
	PLUM KLMNOPQRST 2 Bright A_SpawnObject(DiabolistFireDustSpawner, 0.0, 0.0, 0.0, 16.0)	\
	Goto WaitLoop

#define DIABOLIST_FIRE_DEATH_STATES								\
Death:															\
	TNT1 A 0 A_SpawnObject(DiabolistExplosion)					\
	Stop


thing DiabolistFire1
{
	Radius 4
	Height 8
	
	+NOBLOCKMAP
	+NOGRAVITY
	+NOCLIP

	States
	{
	DIABOLIST_FIRE_SPAWN_STATES
	WaitLoop:
		// There are 6 frames in between each spawning of the flames in the
		// Diabolist definition, so just reduce this by 6 frames (2 x 3)
		// for each successive fire object
		TNT1 AAAAAAAAAAAAAAAAAAAAA 2 A_SpawnObject(DiabolistFireDustSpawner)
		Goto Death
	DIABOLIST_FIRE_DEATH_STATES
	}
}

thing DiabolistFire2 : thing DiabolistFire1
{
	clear states
	States
	{
	DIABOLIST_FIRE_SPAWN_STATES
	WaitLoop:
		TNT1 AAAAAAAAAAAAAAAAAA 2 A_SpawnObject(DiabolistFireDustSpawner)
		Goto Death
	DIABOLIST_FIRE_DEATH_STATES
	}
}

