	DeathSound1:
		TNT1 A 0 A_PlaySound("MACPE1")
		Goto FinishDeath
	DeathSound2:
		TNT1 A 0 A_PlaySound("MACPE2")
		Goto FinishDeath
	DeathSound3:
		TNT1 A 0 A_PlaySound("MACPE3")
		Goto FinishDeath
	FinishDeath:
		VLSE ABCDEFGHIJKL 2 Bright
		Stop
	}
}

