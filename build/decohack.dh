		  }
		  UBER	BB 2 A_Chase
		  UBER C 2 A_Chase
		  UBER C 2
		  {
			A_Chase
			A_PlaySound("UBSTE2")
		  }
		  UBER DD 2  A_Chase
		Loop
	Melee:
	Missile:
		TNT1 A 0 A_RandomJump("RocketAttack", 128)
		UBER Q 20 A_FaceTarget
		UBER RS 3 A_FaceTarget
	ChainLoop:
		UBER I 3 Bright
		{
					A_FaceTarget
					A_PlaySound("VENOM")
