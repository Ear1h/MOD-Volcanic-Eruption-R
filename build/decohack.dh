thing DiabolistExplosion
{
	Height 16
	Radius 8
	SplashGroup 275

	+NOGRAVITY

	States
	{
	Spawn:
		TNT1 A 1
		TNT1 A 0 A_PlaySound(MDIEXP)
		PLUM ABCDEFG 2 Bright A_RadiusDamage(28, 28)
		PLUM HIJ 2 Bright
		TNT1 A 0 A_PlaySound(MDIEXP)
		PLUM ABCDEFG 2 Bright A_RadiusDamage(28, 28)
		PLUM HIJ 2 Bright
		TNT1 A 0 A_PlaySound(MDIEXP)
		PLUM ABCDEFG 2 Bright A_RadiusDamage(28, 28)
		PLUM HIJ 2 Bright
		// Extra time to let sound finish
		TNT1 A 35
		Stop
	}
}

