auto thing SuperSoldat "Nazi Uber Soldat"
{
	//$Category "Monsters/Wolfenstein"
	//$Color 1
	Ednum 10012
	
	SeeSound "UBERST"
	DeathSound "UBERDT"
	Speed 10
	Health 2000
	ReactionTime 8
	Mass 5000
	Radius 24
	Height 64
	
	splashgroup 180
	infightinggroup 180
	projectilegroup  180
	
	+SOLID
	+COUNTKILL
	+SHOOTABLE
