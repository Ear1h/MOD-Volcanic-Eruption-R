// Header
// Woof!
custom thing property Obituary "Obituary" string
custom thing property MeleeObituary "Melee obituary" string
custom thing property SelfObituary "Self obituary" string

// ID24
custom thing property PickupSound "Pickup Sound" string

// Helion & Woof

custom thing property GibHealth "Gib Health" int

 STRINGS
 {
		Obituary_Deh_Actor_172 "%o received a dose of plasma from Zombie Plasma"
