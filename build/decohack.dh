		TBFG A 1 A_Lower
		Loop
	Ready:
		TBFG AAAABBBBCCCCDDDDDDDDDDDDDDDDCCCCBBBB 1 A_WeaponReady
		Loop
	Fire:
		TBFG A 0 Offset(1, 32)
		TBFG D 4
		{
			A_BFGSound
		}
		TBFG C 2 Offset(-1, 33)
	Hold:
		TBFG C 2
		TBFG B 2 Offset(1, 33)
		TBFG B 2 Offset(-1, 34)
		
		TBFG A 1 Offset(-1, 33)
		TBFG A 1
		TBFG A 1 Offset(1, 33)
		TBFG A 1
		
		TBFG A 1 Offset(-1, 33)
		TBFG A 1
		TBFG A 1 Offset(1, 33)
		TBFG A 1
		TBFG A 1 Offset(-1, 33)
		TBFG A 1
		
		TBFG A 1 Offset(-1, 33)
		TBFG A 1
		TBFG A 1 Offset(1, 34)
		TBFG A 1
		TBFG A 1 Offset(-1, 33)
		TBFG A 1 
		TBFG A 1 Offset(1, 33)
		TBFG A 1 Offset(0, 32)
		TNT1 A 0 A_FireBFG
		TNT1 A 0 A_WeaponAlert
		TBFR B 2 Bright A_Light2
		TBFR A 1 Bright A_Light1
		TBFR A 1 Bright
		TBFR B 3 Bright
		TBFR C 2 Bright A_Light0
		TBFR D 2 
		TBFR EF 2
		TBFG A 19 A_ReFireTo("Refire")
    	goto Ready
	Refire:
		TNT1 A 0 A_BFGSound
		Goto Hold
	}
}

