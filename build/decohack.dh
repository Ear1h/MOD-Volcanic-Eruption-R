auto thing Brain1 { +MISSILE }
auto thing RandomGibSeeSound {}
auto thing RandomGibDeathSound {}
// Ranges:
//  x_vel = [-4.0, -8.0]
//  y_vel = [-3.0, 3.0]
//  z_vel = [2.0, 8.0]
// Quick JavaScript functions to generate these:
// ```
// const getRandom = (min, max) => (Math.random() * (max - min) + min).toFixed(1)
// let defineRandom = (count) => { let str = '\n'; for (let i = 0; i < count; i++) { str += `#define RANDOM_GIB_VEL_${i + 1} ${getRandom(-12, -4)}, ${getRandom(-5, 5)}, ${getRandom(8, 16)}\n` } return str }
// defineRandom(8)
// ```
#define RANDOM_GIB_VEL_1 -8.2, -0.1, 11.6
#define RANDOM_GIB_VEL_2 -4.9, 2.7, 8.9
#define RANDOM_GIB_VEL_3 -10.1, 0.1, 14.6
#define RANDOM_GIB_VEL_4 -11.8, -3.9, 15.5
#define RANDOM_GIB_VEL_5 -8.6, 2.9, 12.4
#define RANDOM_GIB_VEL_6 -5.1, -0.3, 8.2
#define RANDOM_GIB_VEL_7 -11.0, -1.6, 14.7
#define RANDOM_GIB_VEL_8 -4.8, 3.5, 9.8

auto thing GibSpawnerM
{
	DUMMY_FLAGS
	
	+MISSILE

	States
	{
	Death:
	Spawn:
		TNT1 A 1
		TNT1 A 0 A_SpawnObject(RandomGibSeeSound)
		RANDOMSPAWN8NODELAY
	Spawn1:
		TNT1 A 0 A_SpawnObject(Gibs1, 0.0, 0.0, 0.0, 0.0, RANDOM_GIB_VEL_1)
		TNT1 A 0 A_SpawnObject(Gibs2, 0.0, 0.0, 0.0, 0.0, RANDOM_GIB_VEL_2)
		TNT1 A 0 A_SpawnObject(Gibs3, 0.0, 0.0, 0.0, 0.0, RANDOM_GIB_VEL_3)
		TNT1 A 0 A_SpawnObject(Gibs4, 0.0, 0.0, 0.0, 0.0, RANDOM_GIB_VEL_4)
		TNT1 A 1 A_SpawnObject(Brain1, 0.0, 0.0, 0.0, 0.0, RANDOM_GIB_VEL_5)
		Stop
	Spawn2:
		TNT1 A 0 A_SpawnObject(Gibs1, 0.0, 0.0, 0.0, 0.0, RANDOM_GIB_VEL_6)
		TNT1 A 0 A_SpawnObject(Gibs2, 0.0, 0.0, 0.0, 0.0, RANDOM_GIB_VEL_7)
		TNT1 A 0 A_SpawnObject(Gibs3, 0.0, 0.0, 0.0, 0.0, RANDOM_GIB_VEL_8)
		TNT1 A 0 A_SpawnObject(Gibs4, 0.0, 0.0, 0.0, 0.0, RANDOM_GIB_VEL_1)
		TNT1 A 1 A_SpawnObject(Brain1, 0.0, 0.0, 0.0, 0.0, RANDOM_GIB_VEL_2)
		Stop
	Spawn3:
		TNT1 A 0 A_SpawnObject(Gibs1, 0.0, 0.0, 0.0, 0.0, RANDOM_GIB_VEL_3)
		TNT1 A 0 A_SpawnObject(Gibs2, 0.0, 0.0, 0.0, 0.0, RANDOM_GIB_VEL_4)
		TNT1 A 0 A_SpawnObject(Gibs3, 0.0, 0.0, 0.0, 0.0, RANDOM_GIB_VEL_5)
		TNT1 A 0 A_SpawnObject(Gibs4, 0.0, 0.0, 0.0, 0.0, RANDOM_GIB_VEL_6)
		TNT1 A 1 A_SpawnObject(Brain1, 0.0, 0.0, 0.0, 0.0, RANDOM_GIB_VEL_7)
		Stop
	Spawn4:
		TNT1 A 0 A_SpawnObject(Gibs1, 0.0, 0.0, 0.0, 0.0, RANDOM_GIB_VEL_8)
		TNT1 A 0 A_SpawnObject(Gibs2, 0.0, 0.0, 0.0, 0.0, RANDOM_GIB_VEL_1)
		TNT1 A 0 A_SpawnObject(Gibs3, 0.0, 0.0, 0.0, 0.0, RANDOM_GIB_VEL_2)
		TNT1 A 0 A_SpawnObject(Gibs4, 0.0, 0.0, 0.0, 0.0, RANDOM_GIB_VEL_3)
		TNT1 A 1 A_SpawnObject(Brain1, 0.0, 0.0, 0.0, 0.0, RANDOM_GIB_VEL_4)
		Stop
	Spawn5:
		TNT1 A 0 A_SpawnObject(Gibs1, 0.0, 0.0, 0.0, 0.0, RANDOM_GIB_VEL_5)
		TNT1 A 0 A_SpawnObject(Gibs2, 0.0, 0.0, 0.0, 0.0, RANDOM_GIB_VEL_6)
		TNT1 A 0 A_SpawnObject(Gibs3, 0.0, 0.0, 0.0, 0.0, RANDOM_GIB_VEL_7)
		TNT1 A 0 A_SpawnObject(Gibs4, 0.0, 0.0, 0.0, 0.0, RANDOM_GIB_VEL_8)
		TNT1 A 1 A_SpawnObject(Brain1, 0.0, 0.0, 0.0, 0.0, RANDOM_GIB_VEL_1)
		Stop
	Spawn6:
		TNT1 A 0 A_SpawnObject(Gibs1, 0.0, 0.0, 0.0, 0.0, RANDOM_GIB_VEL_2)
		TNT1 A 0 A_SpawnObject(Gibs2, 0.0, 0.0, 0.0, 0.0, RANDOM_GIB_VEL_3)
		TNT1 A 0 A_SpawnObject(Gibs3, 0.0, 0.0, 0.0, 0.0, RANDOM_GIB_VEL_4)
		TNT1 A 0 A_SpawnObject(Gibs4, 0.0, 0.0, 0.0, 0.0, RANDOM_GIB_VEL_5)
		TNT1 A 1 A_SpawnObject(Brain1, 0.0, 0.0, 0.0, 0.0, RANDOM_GIB_VEL_6)
		Stop
	Spawn7:
		TNT1 A 0 A_SpawnObject(Gibs1, 0.0, 0.0, 0.0, 0.0, RANDOM_GIB_VEL_7)
		TNT1 A 0 A_SpawnObject(Gibs2, 0.0, 0.0, 0.0, 0.0, RANDOM_GIB_VEL_8)
