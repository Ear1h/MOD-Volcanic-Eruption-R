	{
	Spawn:
		TNT1 A 1
		TNT1 A 0 A_RandomJump(Spawn2, 1D4)
		TNT1 A 0 A_RandomJump(Spawn3, 1D3)
		TNT1 A 0 A_RandomJump(Spawn4, 1D2)
		Goto Spawn1
	// Random spawn states taken from Smooth Doom 21
	Spawn1:
		TNT1 A 1 A_SpawnObject(TorturedSoulChunk, 0.0, -1.0, -0.5, 0.4, 4.1, 2.2, 12.0)
		stop
	Spawn2:
		TNT1 A 1 A_SpawnObject(TorturedSoulChunk, 0.0, 0.8, -0.3, -0.6, -3.0, 1.5, 6.7)
		stop
	Spawn3:
		TNT1 A 1 A_SpawnObject(TorturedSoulChunk, 0.0, -0.4, -0.0, 0.3, -2.4, -4.0, 7.4)
		stop
	Spawn4:
		TNT1 A 1 A_SpawnObject(TorturedSoulChunk, 0.0, -0.2, 0.2, -1.0, -4.6, -3.7, 9.8)
		stop
	}
}

