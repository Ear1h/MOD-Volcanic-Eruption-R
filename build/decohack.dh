auto thing PyroDemon: thing BaronOfHell "Fire Baron"
{
	//$Category "Monsters/Nobles"
	//$Color 2
	EdNum 10014

	Health 1200
	Speed 10
	Radius 24
	Height 64
	ReactionTime 8
	PainChance 10
	Mass 1000
	projectilegroup 181
	SplashGroup 181

	clear flags
	+SOLID
	+SHOOTABLE
	+COUNTKILL
	+NOBLOOD

	SeeSound  "PYSIT"
	
	clear states

	states
	{
			Spawn:
		PYRO A 10 A_Look
		Loop
	See:
		PYRO AA 3 A_Chase
		PYRO BB 3 A_Chase
		PYRO CC 3 A_Chase
		PYRO DD 3 A_Chase
		Loop
	Missile:
		PYRO MN 8 Bright A_FaceTarget
		PYRO O 4 Bright A_MonsterProjectile (PyroBall)
		PYRO P 4 Bright
		Goto See
	Pain:
		PYRO Q 2
		PYRO Q 2 A_Pain
		Goto See
		
	// ****************************
	// DAMAGE TYPE DEATH SWITCHES
	// ****************************
	Death:
		TNT1 A 0 A_FaceTarget
		TNT1 A 0 A_Fall
		TNT1 A 0 A_JumpIfTargetCloser("DeathRandom2", 64.0)
		Goto DeathRandom1
		
	XDeath:
		TNT1 A 0 A_FaceTarget
		TNT1 A 0 A_Fall
		Goto TorsolessDeath
		
	DeathRandom1:
		TNT1 A 0 A_RandomJump("HeadlessDeath", 1D2)
		Goto RegularDeath
		
	DeathRandom2:
		TNT1 A 0 A_RandomJump("TorsolessDeath", 1D3)
		TNT1 A 0 A_RandomJump("HeadlessDeath", 1D2)
		Goto RegularDeath
	
	
	// ****************************
	// DEATH ANIMATIONS
	// ****************************
	RegularDeath:
		TNT1 A 0 A_FaceTarget
		TNT1 A 0 A_Stop
		TNT1 A 0 A_Scream
		TNT1 A 0 A_Fall
		PYD1 A 16
		PYD1 BBBBCCCCDDDDEEEE 1
		PYD1 F 0 A_PlaySound("PYFD1")
		PYD1 F 4
		PYD1 GGGGHHHHIIIIJJJJKKLL 1
		PYD1 M -1
		Stop
	
	HeadlessDeath:
		TNT1 A 0 A_FaceTarget
		TNT1 A 0 A_Stop
		TNT1 A 0 A_SpawnObject(PyroDemonHead, -180.0, 0.0, 0.0, 56.0, 10.0, 0.0, 6.0)
		TNT1 A 0 A_SpawnObject(PyroDemonHorn1, 43.0, 0.0, 0.0, 60.0, 5.0, 0.0, 4.0)
		TNT1 A 0 A_SpawnObject(PyroDemonHorn1, 098.0, 0.0, 0.0, 62.0, 7.0, 0.0, 1.0)
		TNT1 A 0 A_Scream
		TNT1 A 0 A_Fall
		PYD2 A 16
		PYD2 BBBBCCCCDDDDEEEE 1
		PYD2 F 0 A_PlaySound("PYFD1")
		PYD2 FFFF 1 
		PYD1 GGGGHHHHIIIIJJJJKKLL 1 
		PYD1 M -1
		Stop
	
	TorsolessDeath:
		TNT1 A 0 A_FaceTarget
		TNT1 A 0 A_Stop
		TNT1 A 0 A_SpawnObject(PyroDemonHead, -180.0, 0.0, 0.0, 56.0, 10.0, 0.0, 6.0)
		TNT1 A 0 A_SpawnObject(PyroDemonHorn1, 43.0, 0.0, 0.0, 60.0, 5.0, 0.0, 4.0)
		TNT1 A 0 A_SpawnObject(PyroDemonTorso, 0.0, 0.0, 0.0, 56.0, 10.0, 0.0, 6.0)
		TNT1 A 0 A_SpawnObject(PyroDemonHorn1, 098.0, 0.0, 0.0, 62.0, 7.0, 0.0, 1.0)
		TNT1 A 0 A_Scream
		TNT1 A 0 A_Fall
		PYD3 A 16
		PYD3 B 4
		PYD3 C 12
		PYD3 F 0 A_PlaySound("PYFD1")
		PYD3 FFFF 1
		PYD3 GGGGHHHH 1
		PYD1 IIIIJJJJKKLL 1 
		PYD1 M -1
		Stop
	}
}

