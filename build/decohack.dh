		Goto DeathRandom1
		
	XDeath:
		TNT1 A 0 A_FaceTarget
		TNT1 A 0 A_Fall
		Goto ExplosiveDeath
		
	DeathRandom1:
		TNT1 A 0 A_RandomJump(HeadDeath2, 1D5)
		TNT1 A 0 A_RandomJump(HeadDeath, 1D4)
		TNT1 A 0 A_RandomJump(FlyDeath, 1D3)
		TNT1 A 0 A_RandomJump(ExplosiveDeath, 1D2)
		Goto RegularDeath
		
	DeathRandom2:
		TNT1 A 0 A_RandomJump(	GutsDeath, 1D4)
		TNT1 A 0 A_RandomJump(HeadDeath, 1D3)
		TNT1 A 0 A_RandomJump(ExplosiveDeath, 1D2)
		Goto FlyDeath
	
	
	// ****************************
