    		Loop 
  		See: 
    		DMLS A 2 A_Metal 
    		DMLS ABB 2 A_Chase 
    		DMLS C 2 A_Metal 
    		DMLS CDD 2 A_Chase 
    		DMLS E 2 A_Metal 
    		DMLS EFF 2 A_Chase 
    		Loop 
  		Missile:
    		DMLS A 0  A_RandomJump("Missile2", 144)
    		DMLS A 20 A_FaceTarget
    		DMLS T 1  A_Playsound("BFG")
    		DMLS T 4  A_FaceTarget
    		DMLS T 4  A_FaceTarget
    		DMLS T 5  A_FaceTarget
    		DMLS T 5  A_FaceTarget
    		DMLS T 5  A_FaceTarget
    		DMLS T 5  A_FaceTarget
   			DMLS U 10  BRIGHT A_MonsterProjectile(BFGBall)
   			DMLS A 0  A_RandomJump("Missile3", 96)
		    Goto See
		Missile2:
			DMLS A 20 A_FaceTarget
		ReFire:
		    TNT1 A 0 A_PlaySound("CGFIRE")
			TNT1 A 0 A_MonsterBulletAttack(22.5, 0.0, 1, 15, 1)
			DMLS G 2 BRIGHT A_MonsterBulletAttack(22.5, 0.0, 1, 15, 1)
			TNT1 A 0 A_PlaySound("CGFIRE")
			TNT1 A 0 A_MonsterBulletAttack(22.5, 0.0, 1, 15, 1)
			DMLS H 2 BRIGHT A_MonsterBulletAttack(22.5, 0.0, 1, 15, 1)
		    DMLS H 1 BRIGHT A_SpidRefire 
		    Goto ReFire
		Missile3:
			DMLS A 20 A_FaceTarget
    		DMLS T 1  A_Playsound("BFG")
    		DMLS T 4  A_FaceTarget
    		DMLS T 4  A_FaceTarget
    		DMLS T 5  A_FaceTarget
    		DMLS T 5  A_FaceTarget
    		DMLS T 5  A_FaceTarget
    		DMLS T 5  A_FaceTarget
   			DMLS U 10 BRIGHT A_MonsterProjectile(BFGBall)
   			Goto See
		Pain: 
		    DMLS I 3 
		    DMLS I 3 A_Pain 
		    Goto See 
		Death: 
			DMLS J 0 
		    DMLS J 20 A_SpawnObject(FlyingBloodSpawner, 0.0, 0.0, 0.0, 0.0)
		    DMLS K 10  A_FALL
		    DMLS L 10 A_Scream
			DMLS MNOP 10 A_SpawnObject(FlyingBloodSpawner, 0.0, 0.0, 0.0, 0.0)
			DMLS QR 10 A_SpawnObject(GibSpawnerM, 0.0, 0.0, 0.0, 32.0)
		    DMLS S 30 
		    DMLS S -1  A_BossDeath
		    Stop 
    }
}




auto thing Mine "Mine"
{
	//$Category "Monsters/Objects"
	//$Color 18
	
	EdNum 10052

	Radius 16
	Height 54
	PainChance 0
	Mass 700
	ReactionTime 8

	States
	{
	Spawn:
		LMIN AB 8 Bright A_Look
		Loop
	See:
		LMIN AB 8 Bright A_JumpIfTargetCloser(Melee, 128)
		Loop
	Melee:
		LMIN B 0 A_PlaySound("MINEDE")
		LMIN B 10 A_Die
	Death:
		TNT1 A 0 A_PlaySound("BAREXP")
		EXPL A 3 Bright A_RadiusDamage(40, 128)
		EXPL BCDEF 2 Bright
		TNT1 A 35 // Extra frames to allow explosion sound to finish
		Stop
	}
}

auto thing DiabolistCurseSeeker { +MISSILE }
auto thing DiabolistCurseStatue {}

thing DiabolistCurseStatue "Diabolist Curse Statue"
{
	//$Category "Monsters/Objects"
	//$Color 18
	
	EdNum 10050

	Radius 16
	Height 54
	PainChance 0
	Mass 700
	ReactionTime 8

	+FULLVOLSOUNDS
	+SOLID

	SeeSound "MDISIT"
	
	States
	{
	Spawn:
		DEYE ABCB 6 Bright A_Look
		Loop
	See:
		TNT1 A 0 A_JumpIfTargetInSight(PlaceFire1)
		Goto SkipFire1
	PlaceFire1:
		TNT1 A 0 A_MonsterProjectile(DiabolistCurseSeeker)
	SkipFire1:
		DEYE A 3 Bright
	
		TNT1 A 0 A_JumpIfTargetInSight(PlaceFire2)
		Goto SkipFire2
	PlaceFire2:
		TNT1 A 0 A_MonsterProjectile(DiabolistCurseSeeker)
	SkipFire2:
		DEYE A 3 Bright
	
		TNT1 A 0 A_JumpIfTargetInSight(PlaceFire3)
		Goto SkipFire3
	PlaceFire3:
		TNT1 A 0 A_MonsterProjectile(DiabolistCurseSeeker)
	SkipFire3:
		DEYE B 3 Bright
	
		TNT1 A 0 A_JumpIfTargetInSight(PlaceFire4)
		Goto SkipFire4
	PlaceFire4:
		TNT1 A 0 A_MonsterProjectile(DiabolistCurseSeeker)
	SkipFire4:
		DEYE B 3 Bright

		TNT1 A 0 A_JumpIfTargetInSight(PlaceFire5)
		Goto SkipFire5
	PlaceFire5:
		TNT1 A 0 A_MonsterProjectile(DiabolistCurseSeeker)
	SkipFire5:
		DEYE C 3 Bright
		
		TNT1 A 0 A_JumpIfTargetInSight(PlaceFire6)
		Goto SkipFire6
	PlaceFire6:
		TNT1 A 0 A_MonsterProjectile(DiabolistCurseSeeker)
	SkipFire6:
		DEYE C 3 Bright
	
		TNT1 A 0 A_JumpIfTargetInSight(PlaceFire7)
		Goto SkipFire7
	PlaceFire7:
		TNT1 A 0 A_MonsterProjectile(DiabolistCurseSeeker)
	SkipFire7:
		DEYE B 3 Bright
	
		TNT1 A 0 A_JumpIfTargetInSight(PlaceFire8)
		Goto SkipFire8
	PlaceFire8:
		TNT1 A 0 A_MonsterProjectile(DiabolistCurseSeeker)
	SkipFire8:
		DEYE B 3 Bright
		Goto See
	}
}

thing DiabolistCurseSeeker
{
	Radius 4
	Height 8
	Speed 30
	Mass 100
	
	+NOBLOCKMAP
	+NOGRAVITY
	+MISSILE
	+NOCLIP

	States
	{
	Spawn:
		TNT1 A 1
		TNT1 A 0 A_RandomJump(SkipSound, 200)
		TNT1 A 0 A_PlaySound(MDIFLM)
		Goto SkipSound
	SkipSound:
		TNT1 A 0 A_Fire
		// Attempt at making sure if the player moves out of sight in the 1
		// frame it takes to spawn, that the plume won't spawn. Otherwise it'll
		// spawn right in front of the statue awkwardly
		TNT1 A 0 A_JumpIfTracerInSight(PlaceFire)
		Stop
	PlaceFire:
		TNT1 A 0 A_SpawnObject(DiabolistFireSingle)
		Stop
	}
}

auto thing Tesla "Tesla (Radius 256x256)"
{
	//$Category "Monsters/Objects"
	//$Color 18
	
	EdNum 10051

	Radius 16
	Height 54
	PainChance 0
	Mass 700
	ReactionTime 8

	+SOLID

	States
	{
	Spawn:
		TESL AB 8 Bright A_Look
		TNT1 A 0 A_PlaySound("ZAP1")
		TESL CD 8 Bright A_Look
		TNT1 A 0 A_PlaySound("ZAP2")
		TESL CB 8 Bright A_Look
		TNT1 A 0 A_PlaySound("ZAP3")
		Loop
	See:
		TESL AB 8 Bright A_JumpIfTargetCloser(Zap, 192.0)
		TNT1 A 0 A_PlaySound("ZAP1")
		TESL CD 8 Bright A_JumpIfTargetCloser(Zap, 192.0)
		TNT1 A 0 A_PlaySound("ZAP2")
		TESL CB 8 Bright A_JumpIfTargetCloser(Zap, 192.0)
		TNT1 A 0 A_PlaySound("ZAP3")
		Loop
	Zap:
		TESL E 6 Bright A_RadiusDamage(10, 192)
	ZapLoop:
		TNT1 A 0 A_Playsound("ZPFUCK")
		TESL FG 6 Bright A_RadiusDamage(10, 192)
		goto See
	}
}


// Weapons
Weapon 0 "Fist"
{
	+SILENT
	
	clear states
	
	States
	{
		Ready:
			PUNG A 1 A_WeaponReady
			Loop
		Deselect:
			PUNG A 0 A_Lower
			PUNG A 1 A_Lower
			loop
		Select:
			PUNG A 0 A_Raise
			PUNG A 1
			{
				A_Raise
				A_WeaponSound("FSTPIK")
			}
			goto Ready
		Fire:
			PUNG A 0 Offset(1, 32)
			TNT1 A 0 A_WeaponJump("AnotherKickAss", 96)
			TNT1 A 0 A_WeaponJump("KickAss", 128)
			TNT1 A 0 A_WeaponJump("FistKick", 256)
		FistKick:
			TNT1 A 0 A_WeaponSound("FSTMIS", 0)
			PUNG LBCD 1
			PUNG E 2 A_WeaponMeleeAttack(30, 1, 5.0, "FSTATK", 112.0) 
			PUNG FGHI 1
			PUNG JKL 1
			PUNG A 1
			Goto Ready
		KickAss:
			TNT1 A 0 A_WeaponSound("FSTMIS", 0)
			PUN2 ABC 1
			PUN2 D 2  A_WeaponMeleeAttack(35, 1, 5.0, "FSTATK", 112.0) 
			PUN2 EFGH 1
			PUN2 IJKL 1
			PUN2 A 1
			goto Ready
		AnotherKickAss:
			TNT1 A 0 A_WeaponSound("FSTMIS", 0)
			PUN3 ABC 1
			PUN3 D 3 A_WeaponMeleeAttack(40, 1, 5.0, "FSTATK", 112.0) 
			PUN3 EFGH 1
			PUN3 IJKLMNOP 1
			PUN3 A 1
			goto Ready
	}
}

Weapon WP_PISTOL
{
	clear states
		States
		{
			ready:
				PISG A 1 A_WeaponReady
				Loop
			select:
				PISG A 0 A_Raise
				PISG A 1
				{
					A_Raise
					A_WeaponSound("PISPIK")
				}
				goto Ready
			deselect:
				PISG A 0 A_Lower
				PISG A 1 A_Lower
				loop
			fire:
				PISG A 0 Offset(1, 32)
				PISG A 1
				PISG B 1
				{
					A_GunFlash
					A_ConsumeAmmo
					A_WeaponBulletAttack(0.0, 0.0, 1, 15, 1)
					A_WeaponSound("PISFIR")
				}
				PISG C 1
				PISG DE 2
				PISG F 1 A_ReFire
				goto ready
			
			flash:
				TNT1 A 2 Bright A_Light0
				TNT1 A 2 Bright A_Light1
				goto lightdone
		}
}

Weapon 2 "Shotgun"
{
	ammotype AM_SHELL
	clear states
	
	States
	{
		ready:
			VHTG A 1 A_WeaponReady
			Loop
		select:
			VHTG A 0 A_Raise
			VHTG A 1
			{
				A_Raise
				A_WeaponSound("SHTPIK")
			}
			goto Ready
		deselect:
			VHTG A 0 A_Lower
			VHTG A 1 A_Lower
			loop
		fire:
			VHTG A 0 Offset(1, 32)
			VHTG A 1 
			VHTG B 3
			{
				A_ConsumeAmmo
				A_WeaponBulletAttack(2.0, 2.0, 9, 10, 1)
				A_WeaponSound("SHTFIR")
				A_Light1
			}
			VHTG C 1 A_Light2
			TNT1 A 0 A_Light0
			VHTG DE 1
			VHTG FG 2
			VHTG HIJIH 3
			VHTG GF 2
			VHTG ED 1
			VHTG A 1 A_ReFire
			goto ready
	}
}

