		Goto See
		
	Death:
		TNT1 A 0 A_FaceTarget
		TNT1 A 0 A_Fall
		TNT1 A 0 A_JumpIfTargetCloser(DeathRandom2, 128.0)
		Goto DeathRandom1
		
	XDeath:
		TNT1 A 0 A_FaceTarget
		TNT1 A 0 A_Fall
		Goto ExplosiveDeath
		
	DeathRandom1:
		TNT1 A 0 A_RandomJump(CrackHeadsDeath, 1D5)
		TNT1 A 0 A_RandomJump(HeadDeath, 1D4)
		TNT1 A 0 A_RandomJump(FlyDeath, 1D3)
		TNT1 A 0 A_RandomJump(ExplosiveDeath, 1D2)
		Goto RegularDeath
		
	DeathRandom2:
		TNT1 A 0 A_RandomJump(CrackHeadsDeath, 1D4)
		TNT1 A 0 A_RandomJump(HeadDeath, 1D3)
		TNT1 A 0 A_RandomJump(ExplosiveDeath, 1D2)
		Goto FlyDeath
	
	
	// ****************************
	// DEATH ANIMATIONS
	// ****************************
	RegularDeath:
		TNT1 AA 0 A_SpawnObject(FlyingBloodSpawner, 0.0, 0.0, 0.0, 0.0)
		TNT1 AA 0 A_SpawnObject(FlyingBloodSpawner, 0.0, 0.0, 0.0, 24.0)
		TNT1 A 0 A_Scream
		ZSP2 H 5
		ZSP2 I 5
		ZSP2 J 5
		ZSP2 KL 5 A_Stop
		ZSP2 L -1 A_BossDeath
		Stop
		
	
	FlyDeath:
		TNT1 A 0 A_Scream
		TNT1 A 0 A_SpawnObject(GibSpawnerM, 0.0, 0.0, 0.0, 32.0)
		TNT1 A 0 A_SpawnObject(RocketManHead, -180.0, 0.0, 0.0, 48.0, 1.0, 0.0, 6.0)
		TNT1 AAA 0 A_SpawnObject(FlyingBloodSpawner, 0.0, 0.0, 0.0, 12.0)
		ZSP5 LM 4
		ZSP5 N 4
		ZSP5 O 2
		TNT1 AAA 0 A_SpawnObject(FlyingBloodSpawner, 0.0, 0.0, 0.0, -12.0)
		ZSP5 P -1 A_BossDeath
		Stop
		
	ExplosiveDeath:
		TNT1 A 0 A_SpawnObject(GibSpawnerM, 0.0, 0.0, 0.0, 32.0)
		ZSP5 G 0 
		ZSP5 H 5
		ZSP5 I 5 A_XScream
		ZSP5 J 5 A_Fall
		TNT1 AAA 0 A_SpawnObject(FlyingBloodSpawner, 0.0, 0.0, 0.0, -12.0)
		ZSP5 K 5
		ZSP5 K -1 A_BossDeath
		Stop 
		
	HeadDeath:
		TNT1 A 0 A_SpawnObject(GibSpawnerM, 0.0, 0.0, 0.0, 32.0)
		ZHE9 A 4
		ZHE9 B 4 A_SpawnObject(ZManHead, -180.0, 0.0, 0.0, 48.0, 1.0, 0.0, 6.0)
		ZHE9 C 4
		ZHE9 D 4
		ZHE9 E 4
		ZHE9 E -1 A_BossDeath
		Stop
		
	CrackHeadsDeath:
		TNT1 A 0 A_SpawnObject(GibSpawnerM, 0.0, 0.0, 0.0, 32.0)
		ZSP5 A 5
		ZSP5 B 5
		TNT1 AAA 0 A_SpawnObject(FlyingBloodSpawner, 0.0, 0.0, 0.0, -12.0)
		ZSP5 C 5
		ZSP5 D 5
		ZSP5 EF 5
		ZSP5 F -1 A_BossDeath
		Stop
	}
}

