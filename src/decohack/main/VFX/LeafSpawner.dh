	Radius 0
	Height 0
	
	+NOBLOCKMAP
	+NOGRAVITY
	+MISSILE
	-SOLID
	
	States
	{
		Spawn:
			LEF2 ABCDEFGHI 4
			loop
		Death:
			LEF3 C 175
			stop
	}
}

Auto thing LeafsSpawner "Leafs Spawner (256x256)"
