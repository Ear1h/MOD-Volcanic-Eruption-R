auto thing LeafsFallVFX "Leaf VFX"
{
	EdNum -1
	
	Radius 0
	Height 0
	
	+NOBLOCKMAP
	+NOGRAVITY
	+MISSILE
	-SOLID
	
	States
	{
		Spawn:
			LEF1 ABCDEFGHI 4
			loop
		Death:
			LEF3 D 175
			stop
	}
}

auto thing LeafsFallVFX2 "Leaf VFX 2"
{
