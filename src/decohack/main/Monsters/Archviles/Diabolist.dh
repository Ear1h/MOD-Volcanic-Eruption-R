thing DiabolistFireSingle : thing DiabolistFire1
{
	clear states
	States
	{
	Spawn:
		TNT1 A 1
		TNT1 A 0 A_RandomJump(SkipSound, 180)
		TNT1 A 0 A_PlaySound(MDIFLM)
		Goto SkipSound
	SkipSound:
		PLUM KLMNOPQRST 2 Bright A_SpawnObject(DiabolistFireDustSpawner, 0.0, 0.0, 0.0, 16.0)
		Goto WaitLoop
	WaitLoop:
		TNT1 AAAAAAAAAAAA 2 A_SpawnObject(DiabolistFireDustSpawner)
		Goto Death
	Death:
		TNT1 A 0 A_SpawnObject(DiabolistExplosionSingle)
		Stop
	}
}

thing DiabolistExplosionSingle
{
	Height 16
	Radius 8
	SplashGroup 275

	+NOGRAVITY

	States
	{
	Spawn:
		TNT1 A 1
		TNT1 A 0 A_RandomJump(SkipSound, 180)
		TNT1 A 0 A_PlaySound(MDIEXP)
		Goto SkipSound
	SkipSound:
		PLUM ABCDEFG 2 Bright A_RadiusDamage(28, 28)
		PLUM HIJ 2 Bright
		// Extra time to let sound finish
		TNT1 A 35
		Stop
	}
}
