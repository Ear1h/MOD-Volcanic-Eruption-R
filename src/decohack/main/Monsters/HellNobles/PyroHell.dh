		TNT1 A 0 A_RemoveFlags(NOBLOCKMAP)
		PYCL D 500
		Stop
    }
}

thing PyroDemonHorn1
{
    Radius 4
    Height 8
	Speed 7
	Mass 4
	
	+NOBLOCKMAP
	+DROPOFF
	+TELEPORT
	+MISSILE
	
    States
    {
    Spawn:
		PHN1 ABCDEFGH 3
		Loop
    Death:
		TNT1 A 0 A_RemoveFlags(NOBLOCKMAP)
		PHN1 D 500
		Stop
    }
}

thing PyroDemonHorn2 : thing PyroDemonHorn1
{
    States
    {
    Spawn:
		PHN2 HGFEDCBA 3
		Loop
    Death:
		TNT1 A 0 A_RemoveFlags(NOBLOCKMAP)
		PHN2 A 500
		Stop
    }
}