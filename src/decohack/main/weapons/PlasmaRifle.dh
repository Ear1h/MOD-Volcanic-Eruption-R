weapon PlasmaRifle
{
	clear states
	
	States
	{
	Select:
		PLSG A 0 A_Raise
		PLSG A 1
		{
			A_Raise
			A_WeaponSound("PLSUSE")
		}
		Goto Ready
	Deselect:
		PLSG A 0 A_Lower
		PLSG A 1 A_Lower
		Loop
	Ready:
		PLSG A 1 A_WeaponReady
		Loop
	Fire:
		PLSG A 0 Offset(1, 32)
		PLSG A 3 A_FirePlasma
		PLSG B 2 A_ReFire
		PLSG CDEFGFEDCB 2
		Goto Ready
	Flash:
		PLSF A 1 Bright A_Light1
		PLSF B 1 Bright
		PLSF CDEF 1 Bright A_Light2
		Goto LightDone
	}
}